# Copy this file to .env and fill in your API keys
OPENAI_API_KEY=sk-...
SEMANTIC_SCHOLAR_API_KEY=...

# Tavily — used to look up real reagent prices from supplier websites
# Get your key at: https://tavily.com
TAVILY_API_KEY=tvly-...

# Supabase (for the feedback / learning loop + material price cache)
# Get these from: supabase.com → Project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ── Email (Resend) — for sending material quotes to suppliers ──────────────────
# Get your key at: https://resend.com
RESEND_API_KEY=re_...
# Must be a verified sender domain in your Resend account.
# For quick testing use: onboarding@resend.dev (Resend's built-in test address)
FROM_EMAIL=onboarding@resend.dev

# ── ElevenLabs — for voice conversation with the LabAgent ─────────────────────
# Get your key at: https://elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY=sk_...
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase table required for price caching ──────────────────────────────────
# Run this SQL in your Supabase project (SQL Editor → New query):
#
#   CREATE TABLE material_prices (
#       catalog_number TEXT NOT NULL,
#       supplier       TEXT NOT NULL,
#       name           TEXT,
#       unit_price     FLOAT NOT NULL,
#       source         TEXT DEFAULT 'llm',
#       updated_at     TIMESTAMPTZ DEFAULT NOW(),
#       PRIMARY KEY (catalog_number, supplier)
#   );
# ──────────────────────────────────────────────────────────────────────────────
